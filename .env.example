# ============================================
# NEXUS AI - Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx   # Your channel ID (negative for channels)
TELEGRAM_ADMIN_ID=your_personal_user_id

# --- Anthropic (for Sentiment Agent AI analysis) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Broker APIs (optional - for live execution) ---
# Binance
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true   # Set false only when fully tested

# Alpaca (US Stocks)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///nexus_ai.db
# For production: postgresql+asyncpg://user:pass@localhost/nexus_ai

# --- System Settings ---
RISK_PER_TRADE=0.01       # 1% of account per trade (never exceed 0.02)
ACCOUNT_BALANCE=10000     # Starting paper balance in USD
MIN_CONFIDENCE=65         # Only fire signals above this confidence %
SIGNAL_INTERVAL_MINS=15   # How often agents run (15 = 15-min candles)
PAPER_TRADING=true        # Always start with paper trading!

# --- Admin Dashboard & API ---
ADMIN_SECRET=change-this-to-a-strong-secret

# --- Watchlist (comma-separated) ---
CRYPTO_WATCHLIST=BTC-USD,ETH-USD,SOL-USD,BNB-USD,AVAX-USD
STOCKS_WATCHLIST=NVDA,AAPL,TSLA,SPY,QQQ
FOREX_WATCHLIST=EURUSD=X,GBPUSD=X,USDJPY=X

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/nexus_ai.log
